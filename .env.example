# Server
SERVER_PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
MAX_BODY_SIZE=10485760

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=devbrain
DB_PASSWORD=your_secure_password_here
DB_NAME=devbrain
DB_SSLMODE=disable

# JWT
JWT_SECRET=your_super_secret_key_at_least_32_characters_long
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=168h

# Security
RATE_LIMIT=10
RATE_LIMIT_WINDOW=1m

# Argon2 Password Hashing
ARGON2_MEMORY=65536
ARGON2_ITERATIONS=3
ARGON2_SALT_LEN=16
ARGON2_KEY_LEN=32
